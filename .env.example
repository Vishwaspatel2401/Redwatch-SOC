# Copy this file to .env and fill in your values
# Used by docker-compose to inject into the backend container

# Required
OPENAI_API_KEY=sk-your-openai-key-here
JWT_SECRET_KEY=change-this-to-a-random-64-char-string-in-production

# Optional — enables SHA256 hash lookups on ZScaler logs
VIRUSTOTAL_API_KEY=your-vt-key-here
